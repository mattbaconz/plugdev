# PlugDev configuration example
type: plugin
server: paper
version: "1.21.4"
port: 25565

build:
  system: gradle
  task: build
  jarTask: shadowJar

client:
  launcher: auto
  instance: plugdev-1.21.4
  offlineName: DevPlayer

jvm:
  memory: 1G

dev:
  gamemode: creative
  world: void
  op: true
  peaceful: true
  onlineMode: false

watch:
  paths:
    - src/
  debounceMs: 300
  reload:
    java: safe

# Via* always; add more from plugin.yml softdepend or: plugdev deps add luckperms
# deps:
