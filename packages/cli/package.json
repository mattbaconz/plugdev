{
  "name": "@plugdev/cli",
  "version": "0.4.4",
  "description": "npm run dev for Minecraft plugins and mods",
  "author": "PLUG Labs",
  "homepage": "https://github.com/mattbaconz/plugdev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattbaconz/plugdev.git"
  },
  "bugs": {
    "url": "https://github.com/mattbaconz/plugdev/issues"
  },
  "keywords": [
    "minecraft",
    "paper",
    "spigot",
    "plugin",
    "dev-server",
    "cli",
    "gradle"
  ],
  "type": "module",
  "bin": {
    "plugdev": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "bootstrap",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "prepublishOnly": "cd ../.. && npm run build"
  },
  "dependencies": {
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "ajv": "^8.17.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
