{
  "name": "@plugdev/cli",
  "version": "0.1.0",
  "description": "npm run dev for Minecraft Paper plugins",
  "type": "module",
  "bin": {
    "plugdev": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "bootstrap"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "node --test dist/**/*.test.js 2>/dev/null || node --import tsx --test src/**/*.test.ts",
    "prepublishOnly": "cd ../.. && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
