{
  "name": "@plugdev/mcp",
  "version": "0.1.1",
  "description": "MCP server for PlugDev — agent-controllable Minecraft dev environment",
  "author": "PLUG Labs",
  "homepage": "https://github.com/mattbaconz/plugdev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattbaconz/plugdev.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/mattbaconz/plugdev/issues"
  },
  "type": "module",
  "bin": {
    "plugdev-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "mcp-config.example.json"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "cd ../.. && npm run build -w @plugdev/mcp",
    "smoke": "node scripts/smoke.mjs",
    "test": "node --import tsx --test src/json.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "execa": "^9.5.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
